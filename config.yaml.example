# gohook configuration example
# Copy to config.yaml and fill in your values

# ─── OpenClaw Integration ─────────────────────────────────────────────────────
# gohook notifies OpenClaw's agent webhook endpoint:
#
#   POST /hooks/agent
#
# Hook naming convention: <agentId>:<event>
#   name      → identifies the hook type (e.g. "mail:talk-to-my-tashi")
#   agentId   → which OpenClaw agent handles this (must be in allowedAgentIds)
#   deliver   → false: silent background processing | true: surface to user
#   wakeMode  → "now": process immediately | "next-heartbeat": queue for next check
#
# Token: find it in openclaw.json → hooks.token
# Tailscale URL: https://MACHINENAME.TAILNET.ts.net/hooks/agent
# See: https://docs.openclaw.ai/automation/webhook
# ─────────────────────────────────────────────────────────────────────────────

# Gmail account to watch
account: user@example.com


pubsub:
  project_id: your-gcp-project-id
  topic: projects/your-gcp-project-id/topics/gmail-hook
  subscription: projects/your-gcp-project-id/subscriptions/gmail-hook-sub

triggers:
  # Trigger on a specific Gmail label (e.g. "talk-to-my-tashi")
  - name: talk-to-my-tashi
    condition:
      labels_added: ["Label_15"]   # Gmail label ID — find via Gmail API labels.list
    webhook:
      url: https://YOUR_OPENCLAW_HOST/hooks/agent
      method: POST
      headers:
        Authorization: "Bearer YOUR_HOOKS_TOKEN"
      # Template variables: {{message_id}}, {{thread_id}}, {{subject}},
      #                     {{from}}, {{to}}, {{snippet}}, {{labels}}, {{body}}
      payload_template: |
        {
          "message": "mail:talk-to-my-tashi\nMessage-ID: {{message_id}}\nFrom: {{from}}\nSubject: {{subject}}\n\n{{body}}",
          "name": "mail",
          "agentId": "mail",
          "deliver": false,
          "wakeMode": "now"
        }

watch:
  renew_interval_hours: 168

oauth:
  # Path to the OAuth client credentials file (client_id + client_secret)
  # Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
  credentials_file: ~/path/to/client_credentials.json
  # Where gohook stores its token (created once via: python gohook.py --auth)
  token_file: ~/.gohook_token.json
